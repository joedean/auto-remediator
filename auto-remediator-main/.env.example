# Required: OpenAI API key
OPENAI_API_KEY=

# Required: GitHub Personal Access Token for MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Required: Path to GitHub MCP server binary
GITHUB_MCP_SERVER_PATH=~/github-mcp/github-mcp-server

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Preview fixes without applying them
DRY_RUN=false

GITHUB_OWNER="RealPage"

GITHUB_REPO="agent-leasing"

ELASTIC_SPACE="mlops"

ELASTIC_SERVICE_NAME="agent-leasing"